{
  "$schema": "https://raw.githubusercontent.com/grafana/grafana/main/docs/sources/developers/plugins/plugin.schema.json",
  "type": "datasource",
  "name": "istSOS4",
  "id": "supsi-istsos4-datasource",
  "category": "iot",
  "state": "stable",
  "metrics": true,
  "backend": true,
  "alerting": true,
  "executable": "gpx_ist_sos4_grafana",
  "info": {
    "description": "Query OGC SensorThings API and istSOS4 services from Grafana with visual query building, filtering, variables, and OAuth2 proxy support.",
    "author": {
      "name": "SUPSI"
    },
    "keywords": [
      "datasource",
      "istsos4",
      "istsos",
      "sensorthings",
      "sensorthings api",
      "sensor things",
      "ogc",
      "iot",
      "geospatial",
      "observations",
      "sensor data",
      "environmental monitoring"
    ],
    "logos": {
      "small": "img/logo-small.png",
      "large": "img/logo-large.png"
    },
    "links": [
      {
        "name": "repository",
        "url": "https://github.com/istSOS/supsi-istsos4-grafana"
      },
      {
        "name": "license",
        "url": "https://github.com/istSOS/supsi-istsos4-grafana/blob/main/supsi-istsos4/LICENSE"
      },
      {
        "name": "raise issue",
        "url": "https://github.com/istSOS/supsi-istsos4-grafana/issues"
      }
    ],
    "screenshots": [
      {
        "name": "Data source configuration",
        "path": "img/screenshot-datasource-config.png"
      },
      {
        "name": "Query editor and panel creation",
        "path": "img/screenshot-query-panel.png"
      }
    ],
    "version": "%VERSION%",
    "updated": "%TODAY%"
  },
  "dependencies": {
    "grafanaDependency": ">=10.4.0",
    "plugins": []
  },
  "routes": [
    {
      "path": "sensorapi",
      "url": "{{ .JsonData.apiUrl }}"
    },
    {
      "path": "sensorapi-oauth2",
      "url": "{{ .JsonData.apiUrl }}",
      "tokenAuth": {
        "url": "{{ .JsonData.apiUrl }}/{{ .JsonData.oauth2TokenUrl }}",
        "params": {
          "grant_type": "password",
          "username": "{{ .JsonData.oauth2Username }}",
          "password": "{{ .SecureJsonData.oauth2Password }}",
          "client_id": "{{ .JsonData.oauth2ClientId }}",
          "client_secret": "{{ .SecureJsonData.oauth2ClientSecret }}"
        }
      }
    }
  ]
}